{
  "name": "indigo-synthesis",
  "version": "0.0.0",
  "private": true,
  "description": "Clean-slate, self-hosted strength training system restart",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "NEXT_TELEMETRY_DISABLED=1 next start",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "NEXT_TELEMETRY_DISABLED=1 pnpm check && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@fontsource-variable/saira": "5.2.11",
    "@fontsource/atkinson-hyperlegible": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
