# Copy this file to .env.e2e.local for the destructive local Playwright harness.
# The target must remain a disposable database on the same loopback PostgreSQL server
# and use the same explicit username and effective port as DATABASE_URL in .env.local.
E2E_DATABASE_URL=postgresql://indigo:change-me@127.0.0.1:5432/indigo_synthesis_e2e

# Generate a test-only secret of at least 32 characters. Do not reuse the application
# secret from .env.local.
E2E_BETTER_AUTH_SECRET=replace-with-a-distinct-test-secret-at-least-32-characters-long
