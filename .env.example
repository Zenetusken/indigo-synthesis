# Core runtime dependency. No managed provider is required.
DATABASE_URL=postgresql://indigo:change-me@127.0.0.1:5432/indigo_synthesis

# Required only by `pnpm test:integration`. It never falls back to DATABASE_URL.
# Keep this administration connection on a literal loopback host. Its role must be
# allowed to create and drop the harness's cryptographically named disposable databases.
INTEGRATION_ADMIN_DATABASE_URL=postgresql://indigo:change-me@127.0.0.1:5432/postgres

# Generate a unique secret before enabling authentication.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Plain HTTP is supported only on loopback for local development. Set this to the
# externally visible HTTPS origin for every phone, LAN, or other non-loopback install.
BETTER_AUTH_URL=http://127.0.0.1:3000

# `development` enables the conspicuously labeled technical-validation template.
# Production releases must use `reviewed` and require a human-approved content record.
INDIGO_CONTENT_MODE=reviewed

# Enforced in project scripts too; retained here for direct CLI invocations.
NEXT_TELEMETRY_DISABLED=1

# Optional host-local language generation (grounded explanation only). Default off.
# See llm/README.md and docs/architecture/adr/0006-optional-local-grounded-language.md.
INDIGO_LLM_MODE=disabled
# Product policy: local LLM requires a healthy NVIDIA GPU (no CPU product path).
INDIGO_LLM_REQUIRE_GPU=true
# INDIGO_LLM_MODE=local
# INDIGO_LLM_MODEL_ID=qwen3.5-9b-q4_k_m
# INDIGO_LLM_ENDPOINT=http://127.0.0.1:8080/v1
# Fixed product deadline; other values are rejected in local application mode.
# INDIGO_LLM_TIMEOUT_MS=3000
# INDIGO_LLM_MODEL_SHA256=03b74727a860a56338e042c4420bb3f04b2fec5734175f4cb9fa853daf52b7e8
# INDIGO_LLM_ATTESTATION_PATH=tmp/llm-runtime-attestation.json
# INDIGO_LLAMA_SERVER=$HOME/project/llama.cpp-indigo/build/bin/llama-server
# Offload all layers (required for product serve):
INDIGO_LLM_N_GPU_LAYERS=all
# After driver upgrade with mismatch: sudo reboot
# Then: pnpm llm:build-cuda && pnpm llm:measure-gpu
